{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Zork I (Avalonia)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-zork",
      "program": "${workspaceFolder}/src/Faerie.Samples.Zork/bin/Debug/net10.0/Zork.dll",
      "cwd": "${workspaceFolder}/src/Faerie.Samples.Zork/bin/Debug/net10.0",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Haunted House (Avalonia)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-haunted-house",
      "program": "${workspaceFolder}/src/Faerie.Samples.HauntedHouse/bin/Debug/net10.0/HauntedHouse.dll",
      "cwd": "${workspaceFolder}/src/Faerie.Samples.HauntedHouse/bin/Debug/net10.0",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Softporn Adventure (Avalonia)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-softporn",
      "program": "${workspaceFolder}/src/Faerie.Samples.Softporn/bin/Debug/net10.0/Softporn.dll",
      "cwd": "${workspaceFolder}/src/Faerie.Samples.Softporn/bin/Debug/net10.0",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Softporn Adventure (Headless winpath)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-softporn",
      "program": "${workspaceFolder}/src/Faerie.Samples.Softporn/bin/Debug/net10.0/Softporn.dll",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--script",
        "${workspaceFolder}/scripts/softporn-winpath.txt",
        "-o",
        "${workspaceFolder}/scripts/softporn-winpath.transcript.txt",
        "--tee"
      ],
      "stopAtEntry": false
    },
    {
      "name": "Zork I (Headless winpath)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-zork",
      "program": "${workspaceFolder}/src/Faerie.Samples.Zork/bin/Debug/net10.0/Zork.dll",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--script",
        "${workspaceFolder}/scripts/zork1-winpath.txt",
        "-o",
        "${workspaceFolder}/scripts/zork1-winpath.transcript.txt",
        "--seed",
        "1",
        "--tee"
      ],
      "stopAtEntry": false
    }
  ]
}
