{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-solution",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/Faerie.slnx",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-zork",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/Faerie.Samples.Zork/Faerie.Samples.Zork.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-haunted-house",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/Faerie.Samples.HauntedHouse/Faerie.Samples.HauntedHouse.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-softporn",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/Faerie.Samples.Softporn/Faerie.Samples.Softporn.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run: Zork I (Avalonia)",
      "type": "shell",
      "command": "dotnet run --project src/Faerie.Samples.Zork/Faerie.Samples.Zork.csproj",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "run: Haunted House (Avalonia)",
      "type": "shell",
      "command": "dotnet run --project src/Faerie.Samples.HauntedHouse/Faerie.Samples.HauntedHouse.csproj",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "run: Zork I (winpath)",
      "type": "shell",
      "command": "dotnet run --project src/Faerie.Samples.Zork/Faerie.Samples.Zork.csproj -- --script scripts/zork1-winpath.txt -o scripts/zork1-winpath.transcript.txt --seed 1 --tee",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "run: Zork I (smoketest)",
      "type": "shell",
      "command": "dotnet run --project src/Faerie.Samples.Zork/Faerie.Samples.Zork.csproj -- --script scripts/zork1-smoketest.txt -o scripts/zork1-smoketest.transcript.txt",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "run: Softporn Adventure (Avalonia)",
      "type": "shell",
      "command": "dotnet run --project src/Faerie.Samples.Softporn/Faerie.Samples.Softporn.csproj",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "run: Softporn Adventure (winpath)",
      "type": "shell",
      "command": "dotnet run --project src/Faerie.Samples.Softporn/Faerie.Samples.Softporn.csproj -- --script scripts/softporn-winpath.txt -o scripts/softporn-winpath.transcript.txt --tee",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "run: Softporn Adventure (smoketest)",
      "type": "shell",
      "command": "dotnet run --project src/Faerie.Samples.Softporn/Faerie.Samples.Softporn.csproj -- --script scripts/softporn-smoketest.txt -o scripts/softporn-smoketest.transcript.txt",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    }
  ]
}
